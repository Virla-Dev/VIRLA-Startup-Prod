# ─── Banco de Dados e Segurança ───────────────────────────────────
# String de conexão do MongoDB Atlas
DATABASE_URL="mongodb+srv://USUARIO:SENHA@CLUSTER.mongodb.net/CRUD?appName=App"

# Segredo do JWT — use um valor longo e aleatório (>= 32 chars). NUNCA commitar o real.
SECRET="troque-por-um-segredo-aleatorio-longo"

# Tempo de expiração do token de sessão (ex.: 15m, 12h, 7d)
JWT_EXPIRES_IN="7d"

# Chave de EXATOS 32 caracteres para criptografia AES-256-CBC das mensagens
ENCRYPTION_KEY="chave-de-exatos-32-caracteres!!!"

# ─── Sprint 6 — Flag do fluxo de pagamento (defesa em profundidade) ─
# Mesmo com a UI escondida (frontend: VITE_ENABLE_PAYMENT=false), esta
# flag bloqueia a CRIAÇÃO de novas cobranças/billing no backend.
# Leituras, escrow e o webhook do AbacatePay não são afetados.
# Se omitida, o padrão é "true".
ENABLE_PAYMENT="true"

# ─── Firebase (Chat em Tempo Real — Sprint 0) ──────────────────────
# Credenciais da Service Account (Firebase Console > Configurações do
# Projeto > Contas de Serviço > Gerar nova chave privada).
FIREBASE_PROJECT_ID="virla-app"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@virla-app.iam.gserviceaccount.com"
# Cole a private_key do JSON baixado MANTENDO os \n literais (não quebre linha de verdade)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXXXXXXXXXXXXXXXX\n-----END PRIVATE KEY-----\n"
# URL do Realtime Database (Console > Realtime Database > copiar a URL no topo)
FIREBASE_DATABASE_URL="https://virla-app-default-rtdb.firebaseio.com"

# ─── Pagamentos (Abacate Pay) ──────────────────────────────────────
ABACATEPAY_TOKEN="seu_token_abacatepay"
# Segredo do webhook — OBRIGATÓRIO em produção (valida assinatura HMAC)
ABACATEPAY_WEBHOOK_SECRET=""

# ─── Servidor / Socket.io / Logs ───────────────────────────────────
PORT=3002
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# Nível mínimo de log: debug | info | warn | error | fatal
LOG_LEVEL="info"
# Rotação de logs (opcional)
LOG_MAX_SIZE=5242880   # 5MB por arquivo
LOG_MAX_FILES=5        # nº de arquivos mantidos por stream

# Pasta onde os logs em arquivo são gravados (criada automaticamente se não existir)
LOG_DIR="logs"

# Token exigido para acessar /metrics em produção (NODE_ENV=production).
# Em desenvolvimento, o endpoint é liberado sem token.
METRICS_TOKEN="defina-um-token-forte-aqui"

# Limite de upload de áudio em bytes (opcional)
MAX_AUDIO_BYTES=10485760  # 10MB




